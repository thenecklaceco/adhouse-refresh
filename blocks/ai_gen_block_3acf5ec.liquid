{% doc %}
  @prompt
    Create a warm and elegant Contact Us page for AdHouse.in, an online jewellery brand. The tone should be friendly yet sophisticated, reflecting the beauty and trust associated with jewellery shopping.
    Hero/Welcome Section:
    Add a welcoming headline such as "We'd Love to Hear From You ✨" with a subtext like "Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you."
    Contact Details Section:
    Display the following contact information with icons in a clean card or grid layout:
    
    📞 Phone: +91-XXXXXXXXXX (replace with your number)
    💬 WhatsApp: Chat with us on WhatsApp — "Tap to chat instantly!"
    📧 Email: support@adhouse.in
    🕐 Business Hours: Monday – Saturday, 10:00 AM – 7:00 PM IST
    📍 Address: (Add your city/state or warehouse address if applicable)
    
    Social Media Links Section:
    Add a heading like "Follow Us & Stay Inspired 💎" and include clickable icons for:
    
    Instagram – @adhouse.in
    Facebook – AdHouse Jewellery
    Pinterest – AdHouse.in
    YouTube – AdHouse Official (if applicable)
    
    Contact Form Section:
    Include a simple inquiry form with fields for: Name, Email, Phone Number, Order ID (optional), and Message — with a submit button labeled "Send Message 💌"
    Trust/Reassurance Line at Bottom:
    End with a short note like: "We typically respond within 24 hours. Your trust means everything to us — just like every piece of jewellery we craft."
    Design Notes:
    Use gold, ivory, or rose-gold tones to match a jewellery brand aesthetic. Keep the layout minimal, elegant, and mobile-friendly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    padding: 60px 20px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-contact-hero-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    color: {{ block.settings.hero_title_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-contact-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_subtitle_size }}px;
    color: {{ block.settings.hero_subtitle_color }};
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ai-contact-details-section-{{ ai_gen_id }} {
    margin-bottom: 60px;
  }

  .ai-contact-details-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 32px 24px;
    text-align: center;
    box-shadow: 0 4px 12px rgba(131, 84, 71, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-contact-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(131, 84, 71, 0.12);
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    font-size: 32px;
    margin-bottom: 16px;
    display: block;
  }

  .ai-contact-card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
  }

  .ai-contact-card-content-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
  }

  .ai-contact-card-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-contact-card-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-contact-social-section-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-social-title-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: {{ block.settings.social_title_color }};
    margin: 0 0 24px;
  }

  .ai-contact-social-links-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-contact-social-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: {{ block.settings.social_icon_background }};
    color: {{ block.settings.social_icon_color }};
    text-decoration: none;
    font-size: 24px;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-contact-social-link-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    background: {{ block.settings.social_icon_hover_background }};
  }

  .ai-contact-form-section-{{ ai_gen_id }} {
    max-width: 700px;
    margin: 0 auto 60px;
    background: {{ block.settings.form_background }};
    border-radius: {{ block.settings.form_border_radius }}px;
    padding: 40px;
    box-shadow: 0 4px 16px rgba(131, 84, 71, 0.1);
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: {{ block.settings.form_title_color }};
    margin: 0 0 24px;
    text-align: center;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.form_label_color }};
    margin-bottom: 8px;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.form_input_border }};
    border-radius: 8px;
    font-size: 15px;
    color: {{ block.settings.form_input_text }};
    background: {{ block.settings.form_input_background }};
    transition: border-color 0.3s ease;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.form_input_focus_border }};
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background: {{ block.settings.form_button_background }};
    color: {{ block.settings.form_button_text_color }};
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.form_button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    background: #d4edda;
    color: #155724;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    text-align: center;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    background: #f8d7da;
    color: #721c24;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .ai-contact-trust-line-{{ ai_gen_id }} {
    text-align: center;
    font-size: 15px;
    color: {{ block.settings.trust_text_color }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-contact-page-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-contact-hero-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-contact-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.7 }}px;
    }

    .ai-contact-hero-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_subtitle_size | times: 0.9 }}px;
    }

    .ai-contact-details-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-contact-form-section-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-contact-social-title-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<contact-page-{{ ai_gen_id }} class="ai-contact-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    {% if block.settings.show_form %}
      <div class="ai-contact-form-section-{{ ai_gen_id }}">
        <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
        
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <div class="ai-contact-form-success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
              {{ block.settings.form_success_message }}
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="ai-contact-form-error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Name *</label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              aria-required="true"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-form-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Email *</label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              aria-required="true"
              autocomplete="email"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Phone Number</label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-order-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Order ID (Optional)</label>
            <input
              type="text"
              id="contact-order-{{ ai_gen_id }}"
              name="contact[order_id]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Message *</label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-form-textarea-{{ ai_gen_id }}"
              required
              aria-required="true"
            ></textarea>
          </div>

          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.form_button_label }}
          </button>
        {%- endform -%}
      </div>
    {% endif %}

    {% if block.settings.trust_line != blank %}
      <div class="ai-contact-trust-line-{{ ai_gen_id }}">
        {{ block.settings.trust_line }}
      </div>
    {% endif %}
  </div>
</contact-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && form.classList.contains('contact-form')) {
          const successMessage = this.querySelector('.ai-contact-form-success-{{ ai_gen_id }}');
          if (successMessage) {
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      }
    }

    customElements.define('contact-page-{{ ai_gen_id }}', ContactPage{{ ai_gen_id }});
  })();
</script>

