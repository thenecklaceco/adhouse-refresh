{% liquid
  assign metafield_namespace = section.settings.metafield_namespace
  assign metafield_key = section.settings.metafield_key

  assign metafield_value = product.metafields[metafield_namespace][metafield_key]
%}

{% if metafield_value != blank %}
  <div
    id="metafield-accordion-{{ section.id }}"
    class="metafield-accordion-wrapper"
    style="
      --accordion-bg: {{ section.settings.background_color }};
      --accordion-text: {{ section.settings.text_color }};
      --accordion-heading: {{ section.settings.heading_color }};
      --accordion-border: {{ section.settings.border_color }};
      --accordion-padding: {{ section.settings.padding }}px;
      --accordion-radius: {{ section.settings.border_radius }}px;
      --accordion-margin-top: {{ section.settings.margin_top }}px;
      --accordion-margin-bottom: {{ section.settings.margin_bottom }}px;
      --accordion-icon-color: {{ section.settings.icon_color }};
    "
  >
    <details
      class="metafield-accordion"
      {% if section.settings.open_by_default %}
        open
      {% endif %}
    >
      <summary class="metafield-accordion__summary">
        <span class="metafield-accordion__heading">
          {{ section.settings.heading }}
        </span>

        <span class="metafield-accordion__icon">
          +
        </span>
      </summary>

      <div class="metafield-accordion__content rte">
        {% if section.settings.enable_richtext %}
          {{ metafield_value | metafield_tag }}
        {% else %}
          {{ metafield_value }}
        {% endif %}
      </div>
    </details>
  </div>

  <style>
    #metafield-accordion-{{ section.id }} {
      margin-top: var(--accordion-margin-top);
      margin-bottom: var(--accordion-margin-bottom);
    }

    #metafield-accordion-{{ section.id }} .metafield-accordion {
      background: var(--accordion-bg);
      border: 1px solid var(--accordion-border);
      border-radius: var(--accordion-radius);
      overflow: hidden;
    }

    #metafield-accordion-{{ section.id }} .metafield-accordion__summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;

      cursor: pointer;
      list-style: none;

      padding: var(--accordion-padding);
    }

    #metafield-accordion-{{ section.id }}
      .metafield-accordion__summary::-webkit-details-marker {
      display: none;
    }

    #metafield-accordion-{{ section.id }} .metafield-accordion__heading {
      color: var(--accordion-heading);
      font-weight: 600;
      line-height: 1.3;
    }

    #metafield-accordion-{{ section.id }} .metafield-accordion__icon {
      color: var(--accordion-icon-color);
      font-size: 22px;
      line-height: 1;
      transition: transform 0.25s ease;
      flex-shrink: 0;
    }

    #metafield-accordion-{{ section.id }}
      details[open]
      .metafield-accordion__icon {
      transform: rotate(45deg);
    }

    #metafield-accordion-{{ section.id }} .metafield-accordion__content {
      color: var(--accordion-text);

      padding:
        0
        var(--accordion-padding)
        var(--accordion-padding);

      line-height: 1.7;
    }

    @media screen and (max-width: 749px) {
      #metafield-accordion-{{ section.id }}
        .metafield-accordion__summary,
      #metafield-accordion-{{ section.id }}
        .metafield-accordion__content {
        padding-left: calc(var(--accordion-padding) * 0.8);
        padding-right: calc(var(--accordion-padding) * 0.8);
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Metafield Accordion",
  "tag": "section",
  "class": "shopify-section-metafield-accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accordion heading",
      "default": "Product Information"
    },

    {
      "type": "header",
      "content": "Metafield Source"
    },

    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },

    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "care_instructions"
    },

    {
      "type": "checkbox",
      "id": "enable_richtext",
      "label": "Enable rich text rendering",
      "default": true
    },

    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open accordion by default",
      "default": false
    },

    {
      "type": "header",
      "content": "Colors"
    },

    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Content text color",
      "default": "#444444"
    },

    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },

    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#111111"
    },

    {
      "type": "header",
      "content": "Spacing & Shape"
    },

    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 18,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 10,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "margin_top",
      "label": "Top spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16,
      "unit": "px"
    },

    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16,
      "unit": "px"
    }
  ],

  "presets": [
    {
      "name": "Metafield Accordion"
    }
  ]
}
{% endschema %}