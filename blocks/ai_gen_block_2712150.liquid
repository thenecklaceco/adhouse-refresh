{% doc %}
  @prompt
    Create a warm and elegant Contact Us page section for AdHouse.in, an online jewellery brand. The tone should be friendly yet sophisticated.
    
    Include the following sections:
    
    1. Hero/Welcome Section: A welcoming headline "We'd Love to Hear From You ✨" with subtext "Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you." Use a soft warm background aligned with brand color #a46959.
    
    2. Contact Details Section: Display contact info in a clean card grid layout with icons: Phone +91-XXXXXXXXXX, WhatsApp tap to chat instantly via wa.me, Email support@adhouse.in, Business Hours Monday to Saturday 10AM to 7PM IST, Address placeholder.
    
    3. Social Media Links Section: Heading "Follow Us & Stay Inspired 💎" with clickable icon links for Instagram, Facebook, Pinterest, and YouTube. Elegant icon styling for luxury jewellery brand.
    
    Design: warm earthy tones, brand color #a46959 for accents, clean minimal layout, generous whitespace, Jakarta Sans typography, fully responsive mobile-first, all fields customizable via theme editor schema.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-us-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-contact-hero-{{ ai_gen_id }} {
    background-color: {{ block.settings.hero_bg_color }};
    padding: {{ block.settings.hero_padding_mobile }}px 20px;
    text-align: center;
    width: 100%;
  }

  .ai-contact-hero-content-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-contact-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size_mobile }}px;
    color: {{ block.settings.hero_text_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-contact-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_subtext_size_mobile }}px;
    color: {{ block.settings.hero_text_color }};
    line-height: 1.6;
    opacity: 0.9;
  }

  .ai-contact-details-{{ ai_gen_id }} {
    padding: {{ block.settings.details_padding_mobile }}px 20px;
    background-color: {{ block.settings.details_bg_color }};
    width: 100%;
  }

  .ai-contact-details-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-contact-cards-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-contact-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(164, 105, 89, 0.15);
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_bg_color }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .ai-contact-card-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-contact-card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
  }

  .ai-contact-card-text-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-contact-card-link-{{ ai_gen_id }} {
    color: {{ block.settings.card_link_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-contact-card-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-contact-social-{{ ai_gen_id }} {
    padding: {{ block.settings.social_padding_mobile }}px 20px;
    background-color: {{ block.settings.social_bg_color }};
    text-align: center;
    width: 100%;
  }

  .ai-contact-social-container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
  }

  .ai-contact-social-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.social_title_size_mobile }}px;
    color: {{ block.settings.social_text_color }};
    margin: 0 0 32px;
    font-weight: 600;
  }

  .ai-contact-social-icons-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-contact-social-link-{{ ai_gen_id }} {
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.social_icon_bg_color }};
    border-radius: 50%;
    color: {{ block.settings.social_icon_color }};
    text-decoration: none;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-contact-social-link-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    background-color: {{ block.settings.social_icon_hover_bg }};
  }

  .ai-contact-social-link-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.social_icon_size }}px * 0.5);
    height: calc({{ block.settings.social_icon_size }}px * 0.5);
  }

  @media screen and (min-width: 750px) {
    .ai-contact-hero-{{ ai_gen_id }} {
      padding: {{ block.settings.hero_padding_desktop }}px 40px;
    }

    .ai-contact-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size_desktop }}px;
    }

    .ai-contact-hero-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_subtext_size_desktop }}px;
    }

    .ai-contact-details-{{ ai_gen_id }} {
      padding: {{ block.settings.details_padding_desktop }}px 40px;
    }

    .ai-contact-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .ai-contact-social-{{ ai_gen_id }} {
      padding: {{ block.settings.social_padding_desktop }}px 40px;
    }

    .ai-contact-social-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.social_title_size_desktop }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .ai-contact-cards-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }
{% endstyle %}

<contact-us-section-{{ ai_gen_id }} class="ai-contact-us-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-hero-{{ ai_gen_id }}">
    <div class="ai-contact-hero-content-{{ ai_gen_id }}">
      {% if block.settings.hero_title != blank %}
        <h1 class="ai-contact-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
      {% endif %}
      {% if block.settings.hero_subtext != blank %}
        <div class="ai-contact-hero-subtext-{{ ai_gen_id }}">{{ block.settings.hero_subtext }}</div>
      {% endif %}
    </div>
  </div>

  <div class="ai-contact-details-{{ ai_gen_id }}">
    <div class="ai-contact-details-container-{{ ai_gen_id }}">
      <div class="ai-contact-cards-grid-{{ ai_gen_id }}">
        {% if block.settings.show_phone %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <div class="ai-contact-card-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.phone_title }}</h3>
            <p class="ai-contact-card-text-{{ ai_gen_id }}">
              {% if block.settings.phone_number != blank %}
                <a href="tel:{{ block.settings.phone_number | replace: ' ', '' | replace: '-', '' }}" class="ai-contact-card-link-{{ ai_gen_id }}">{{ block.settings.phone_number }}</a>
              {% else %}
                +91-XXXXXXXXXX
              {% endif %}
            </p>
          </div>
        {% endif %}

        {% if block.settings.show_whatsapp %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <div class="ai-contact-card-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </div>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.whatsapp_title }}</h3>
            <p class="ai-contact-card-text-{{ ai_gen_id }}">
              {% if block.settings.whatsapp_number != blank %}
                <a href="https://wa.me/{{ block.settings.whatsapp_number | replace: ' ', '' | replace: '-', '' | replace: '+', '' }}" target="_blank" rel="noopener" class="ai-contact-card-link-{{ ai_gen_id }}">{{ block.settings.whatsapp_text }}</a>
              {% else %}
                Tap to chat instantly
              {% endif %}
            </p>
          </div>
        {% endif %}

        {% if block.settings.show_email %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <div class="ai-contact-card-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.email_title }}</h3>
            <p class="ai-contact-card-text-{{ ai_gen_id }}">
              {% if block.settings.email_address != blank %}
                <a href="mailto:{{ block.settings.email_address }}" class="ai-contact-card-link-{{ ai_gen_id }}">{{ block.settings.email_address }}</a>
              {% else %}
                support@adhouse.in
              {% endif %}
            </p>
          </div>
        {% endif %}

        {% if block.settings.show_hours %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <div class="ai-contact-card-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.hours_title }}</h3>
            <p class="ai-contact-card-text-{{ ai_gen_id }}">{{ block.settings.hours_text }}</p>
          </div>
        {% endif %}

        {% if block.settings.show_address %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <div class="ai-contact-card-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.address_title }}</h3>
            <p class="ai-contact-card-text-{{ ai_gen_id }}">{{ block.settings.address_text }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="ai-contact-social-{{ ai_gen_id }}">
    <div class="ai-contact-social-container-{{ ai_gen_id }}">
      {% if block.settings.social_title != blank %}
        <h2 class="ai-contact-social-title-{{ ai_gen_id }}">{{ block.settings.social_title }}</h2>
      {% endif %}
      <div class="ai-contact-social-icons-{{ ai_gen_id }}">
        {% if block.settings.instagram_url != blank %}
          <a href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.facebook_url != blank %}
          <a href="{{ block.settings.facebook_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.pinterest_url != blank %}
          <a href="{{ block.settings.pinterest_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z"/>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.youtube_url != blank %}
          <a href="{{ block.settings.youtube_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</contact-us-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactUsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('contact-us-section-{{ ai_gen_id }}', ContactUsSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact us",
  "settings": [
    {
      "type": "header",
      "content": "Hero section"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title",
      "label": "Title",
      "default": "We'd Love to Hear From You ✨"
    },
    {
      "type": "richtext",
      "id": "hero_subtext",
      "label": "Subtext",
      "default": "<p>Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you.</p>"
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Background color",
      "default": "#f7ede8"
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Text color",
      "default": "#a46959"
    },
    {
      "type": "range",
      "id": "hero_title_size_mobile",
      "label": "Title size (mobile)",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "hero_title_size_desktop",
      "label": "Title size (desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "hero_subtext_size_mobile",
      "label": "Subtext size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "hero_subtext_size_desktop",
      "label": "Subtext size (desktop)",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "hero_padding_mobile",
      "label": "Padding (mobile)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "hero_padding_desktop",
      "label": "Padding (desktop)",
      "min": 40,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Contact details"
    },
    {
      "type": "color",
      "id": "details_bg_color",
      "label": "Background color",
      "default": "#fcfbfa"
    },
    {
      "type": "range",
      "id": "details_padding_mobile",
      "label": "Padding (mobile)",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
