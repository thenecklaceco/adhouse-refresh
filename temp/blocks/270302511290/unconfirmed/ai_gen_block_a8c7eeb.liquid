{% doc %}
  @prompt
    Create a responsive collection list grid where the number of columns automatically adapts to the screen size. On large desktop screens, show more columns (e.g., 4-5 per row); on medium screens show 3; on tablets show 2; and on mobile show 1 or 2. Use CSS Grid with auto-fill and minmax so collection cards naturally fill available space and wrap to the next row when there isn't enough room. No fixed column count — let the grid be fully fluid and responsive., I want there should be flag to make the card circulr like border radius 50% and there should be option to hide collection product and setting font size, color, position of the collection title.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-collection-grid__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
  }

  .ai-collection-grid__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-collection-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-collection-grid__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax({{ block.settings.min_card_width }}px, 1fr));
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-collection-grid__card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    {% if block.settings.circular_cards %}
      border-radius: 50%;
    {% else %}
      border-radius: {{ block.settings.card_border_radius }}px;
    {% endif %}
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-collection-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_shadow_offset }}px {{ block.settings.hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-collection-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.circular_cards %}
      padding-top: 100%;
    {% else %}
      padding-top: {{ block.settings.image_aspect_ratio }}%;
    {% endif %}
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collection-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-collection-grid__card-{{ ai_gen_id }}:hover .ai-collection-grid__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom_scale }});
  }

  .ai-collection-grid__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collection-grid__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-grid__content-{{ ai_gen_id }} {
    {% if block.settings.circular_cards %}
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      width: 80%;
      padding: 0;
    {% else %}
      padding: {{ block.settings.card_padding }}px;
      display: flex;
      flex-direction: column;
      gap: {{ block.settings.content_gap }}px;
      flex-grow: 1;
      text-align: {{ block.settings.title_position }};
    {% endif %}
  }

  .ai-collection-grid__collection-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.collection_title_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.collection_title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-collection-grid__collection-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_count_size }}px;
    color: {{ block.settings.product_count_color }};
    margin: 0;
  }

  .ai-collection-grid__collection-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-collection-grid__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  .ai-collection-grid__empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(auto-fill, minmax({{ block.settings.min_card_width_mobile }}px, 1fr));
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-collection-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-collection-grid__collection-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.collection_title_size | times: 0.9 }}px;
    }

    {% unless block.settings.circular_cards %}
      .ai-collection-grid__content-{{ ai_gen_id }} {
        padding: {{ block.settings.card_padding | times: 0.8 }}px;
      }
    {% endunless %}
  }
{% endstyle %}

<div class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-collection-grid__header-{{ ai_gen_id }}">
        <h2 class="ai-collection-grid__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection_list != blank %}
      <div class="ai-collection-grid__grid-{{ ai_gen_id }}">
        {% for collection in block.settings.collection_list %}
          <a
            href="{{ collection.url }}"
            class="ai-collection-grid__card-{{ ai_gen_id }}"
          >
            <div class="ai-collection-grid__image-wrapper-{{ ai_gen_id }}">
              {% if collection.featured_image %}
                <img
                  src="{{ collection.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.featured_image.alt | escape }}"
                  class="ai-collection-grid__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-collection-grid__image-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-collection-grid__content-{{ ai_gen_id }}">
              {% if block.settings.show_collection_title %}
                <h3 class="ai-collection-grid__collection-title-{{ ai_gen_id }}">
                  {{ collection.title }}
                </h3>
              {% endif %}

              {% if block.settings.show_product_count %}
                <p class="ai-collection-grid__collection-count-{{ ai_gen_id }}">
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    product
                  {% else %}
                    products
                  {% endif %}
                </p>
              {% endif %}

              {% if block.settings.show_description and collection.description != blank %}
                <div class="ai-collection-grid__collection-description-{{ ai_gen_id }}">
                  {{ collection.description | strip_html | truncate: 120 }}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-collection-grid__empty-state-{{ ai_gen_id }}">
        <p>Next, select collections to display in your grid</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collection_list",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "checkbox",
      "id": "show_collection_title",
      "label": "Show collection title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#422a24"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 40
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "min_card_width",
      "min": 200,
      "max": 400,
      "step": 20,
      "unit": "px",
      "label": "Minimum card width (desktop)",
      "default": 280
    },
    {
      "type": "range",
      "id": "min_card_width_mobile",
      "min": 120,
      "max": 300,
      "step": 20,
      "unit": "px",
      "label": "Minimum card width (mobile)",
      "default": 140
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Grid gap (desktop)",
      "default": 25
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "label": "Grid gap (mobile)",
      "default": 15
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "checkbox",
      "id": "circular_cards",
      "label": "Circular cards",
      "default": false,
      "info": "Makes cards perfectly round with 50% border radius"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#fcfbfa"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Border color",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 18,
      "info": "Ignored when circular cards is enabled"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card padding",
      "default": 20,
      "info": "Ignored when circular cards is enabled"
    },
    {
      "type": "range",
      "id": "content_gap",
      "min": 5,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Content gap",
      "default": 8
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
      "min": 50,
      "max": 150,
      "step": 5,
      "unit": "%",
      "label": "Aspect ratio",
      "default": 100,
      "info": "Ignored when circular cards is enabled"
    },
    {
      "type": "range",
      "id": "image_zoom_scale",
      "min": 1,
      "max": 1.5,
      "step": 0.1,
      "label": "Hover zoom scale",
      "default": 1.1
    },
    {
      "type": "header",
      "content": "Hover effects"
    },
    {
      "type": "range",
      "id": "hover_lift",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Lift distance",
      "default": 4
    },
    {
      "type": "range",
      "id": "hover_shadow_offset",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Shadow offset",
      "default": 10
    },
    {
      "type": "range",
      "id": "hover_shadow_blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 20
    },
    {
      "type": "range",
      "id": "hover_shadow_opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.2
    },
    {
      "type": "header",
      "content": "Collection title"
    },
    {
      "type": "range",
      "id": "collection_title_size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Font size",
      "default": 18
    },
    {
      "type": "color",
      "id": "collection_title_color",
      "label": "Color",
      "default": "#422a24"
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "title_position",
      "label": "Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Ignored when circular cards is enabled"
    },
    {
      "type": "header",
      "content": "Product count"
    },
    {
      "type": "range",
      "id": "product_count_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "color",
      "id": "product_count_color",
      "label": "Color",
      "default": "#a46959"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Collection grid"
    }
  ]
}
{% endschema %}
