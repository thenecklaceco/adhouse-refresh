{% doc %}
  @prompt
    Add a blog which will show custom formatter for page content in shopify 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-content-formatter-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.container_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-blog-content-formatter__header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-content-formatter__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-blog-content-formatter__meta-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
    margin-bottom: {{ block.settings.meta_spacing }}px;
  }

  .ai-blog-content-formatter__meta-{{ ai_gen_id }} {
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-blog-content-formatter__meta-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-blog-content-formatter__featured-image-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.image_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-blog-content-formatter__featured-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    line-height: {{ block.settings.line_height }};
    color: {{ block.settings.content_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} h1,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} h2,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} h3,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} h4,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} h5,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin-top: {{ block.settings.heading_spacing }}px;
    margin-bottom: {{ block.settings.heading_spacing | divided_by: 2 }}px;
    font-weight: 600;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} h1 {
    font-size: {{ block.settings.content_size | times: 2 }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} h2 {
    font-size: {{ block.settings.content_size | times: 1.5 }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.content_size | times: 1.3 }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} h4 {
    font-size: {{ block.settings.content_size | times: 1.1 }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} p {
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} ul,
  .ai-blog-content-formatter__content-{{ ai_gen_id }} ol {
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
    padding-left: 24px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} blockquote {
    border-left: 4px solid {{ block.settings.blockquote_border_color }};
    padding-left: 20px;
    margin: {{ block.settings.paragraph_spacing }}px 0;
    font-style: italic;
    color: {{ block.settings.blockquote_text_color }};
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: {{ block.settings.content_image_radius }}px;
    margin: {{ block.settings.paragraph_spacing }}px 0;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} code {
    background-color: {{ block.settings.code_background }};
    color: {{ block.settings.code_text_color }};
    padding: 2px 6px;
    border-radius: 4px;
    font-family: monospace;
    font-size: {{ block.settings.content_size | times: 0.9 }}px;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} pre {
    background-color: {{ block.settings.code_background }};
    color: {{ block.settings.code_text_color }};
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    margin: {{ block.settings.paragraph_spacing }}px 0;
  }

  .ai-blog-content-formatter__content-{{ ai_gen_id }} pre code {
    background: none;
    padding: 0;
  }

  .ai-blog-content-formatter__tags-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: {{ block.settings.tags_spacing }}px;
  }

  .ai-blog-content-formatter__tags-{{ ai_gen_id }} {
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-blog-content-formatter__tag-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.tag_background }};
    color: {{ block.settings.tag_text_color }};
    border-radius: 16px;
    font-size: {{ block.settings.meta_size | times: 0.9 }}px;
    text-decoration: none;
  }

  .ai-blog-content-formatter__tag-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tag_hover_background }};
  }

  .ai-blog-content-formatter__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blog-content-formatter__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    opacity: 0.3;
  }

  .ai-blog-content-formatter__empty-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.meta_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-blog-content-formatter-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.container_padding | times: 0.6 }}px;
    }

    .ai-blog-content-formatter__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-blog-content-formatter__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size | times: 0.9 }}px;
    }

    .ai-blog-content-formatter__meta-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
  }
{% endstyle %}

<blog-content-formatter-{{ ai_gen_id }}
  class="ai-blog-content-formatter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.selected_blog != blank %}
    {% assign blog = block.settings.selected_blog %}
    {% assign article = blog.articles.first %}

    {% if article %}
      <div class="ai-blog-content-formatter__header-{{ ai_gen_id }}">
        {% if block.settings.show_title %}
          <h1 class="ai-blog-content-formatter__title-{{ ai_gen_id }}">
            {{ article.title }}
          </h1>
        {% endif %}

        {% if block.settings.show_meta %}
          <div class="ai-blog-content-formatter__meta-{{ ai_gen_id }}">
            {% if block.settings.show_author %}
              <div class="ai-blog-content-formatter__meta-item-{{ ai_gen_id }}">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 8C9.65685 8 11 6.65685 11 5C11 3.34315 9.65685 2 8 2C6.34315 2 5 3.34315 5 5C5 6.65685 6.34315 8 8 8Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M14 14C14 11.7909 11.3137 10 8 10C4.68629 10 2 11.7909 2 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ article.author }}</span>
              </div>
            {% endif %}

            {% if block.settings.show_date %}
              <div class="ai-blog-content-formatter__meta-item-{{ ai_gen_id }}">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12.6667 2.66667H3.33333C2.59695 2.66667 2 3.26362 2 4V13.3333C2 14.0697 2.59695 14.6667 3.33333 14.6667H12.6667C13.403 14.6667 14 14.0697 14 13.3333V4C14 3.26362 13.403 2.66667 12.6667 2.66667Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M10.6667 1.33333V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M5.33333 1.33333V4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M2 6.66667H14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ article.published_at | date: block.settings.date_format }}</span>
              </div>
            {% endif %}

            {% if block.settings.show_comment_count and blog.comments_enabled? %}
              <div class="ai-blog-content-formatter__meta-item-{{ ai_gen_id }}">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M14 10C14 10.3536 13.8595 10.6928 13.6095 10.9428C13.3594 11.1929 13.0203 11.3333 12.6667 11.3333H4.66667L2 14V3.33333C2 2.97971 2.14048 2.64057 2.39052 2.39052C2.64057 2.14048 2.97971 2 3.33333 2H12.6667C13.0203 2 13.3594 2.14048 13.6095 2.39052C13.8595 2.64057 14 2.97971 14 3.33333V10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ article.comments_count }} {% if article.comments_count == 1 %}comment{% else %}comments{% endif %}</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_featured_image and article.image %}
        <div class="ai-blog-content-formatter__featured-image-{{ ai_gen_id }}">
          <img
            src="{{ article.image | image_url: width: 1200 }}"
            alt="{{ article.image.alt | escape }}"
            loading="lazy"
            width="{{ article.image.width }}"
            height="{{ article.image.height }}"
          >
        </div>
      {% endif %}

      <div class="ai-blog-content-formatter__content-{{ ai_gen_id }}">
        {{ article.content }}
      </div>

      {% if block.settings.show_tags and article.tags.size > 0 %}
        <div class="ai-blog-content-formatter__tags-{{ ai_gen_id }}">
          {% for tag in article.tags %}
            <a
              href="{{ blog.url }}/tagged/{{ tag | handle }}"
              class="ai-blog-content-formatter__tag-{{ ai_gen_id }}"
            >
              {{ tag }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-blog-content-formatter__empty-{{ ai_gen_id }}">
        <div class="ai-blog-content-formatter__empty-icon-{{ ai_gen_id }}">
          {{ 'blog-apparel-1' | placeholder_svg_tag }}
        </div>
        <p class="ai-blog-content-formatter__empty-text-{{ ai_gen_id }}">
          No articles found in this blog
        </p>
      </div>
    {% endif %}
  {% else %}
    <div class="ai-blog-content-formatter__empty-{{ ai_gen_id }}">
      <div class="ai-blog-content-formatter__empty-icon-{{ ai_gen_id }}">
        {{ 'blog-apparel-1' | placeholder_svg_tag }}
      </div>
      <p class="ai-blog-content-formatter__empty-text-{{ ai_gen_id }}">
        Next, select a blog to display
      </p>
    </div>
  {% endif %}
</blog-content-formatter-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogContentFormatter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.enhanceContent();
      }

      enhanceContent() {
        const content = this.querySelector('.ai-blog-content-formatter__content-{{ ai_gen_id }}');
        if (!content) return;

        const tables = content.querySelectorAll('table');
        tables.forEach(table => {
          if (!table.parentElement.classList.contains('table-wrapper')) {
            const wrapper = document.createElement('div');
            wrapper.style.overflowX = 'auto';
            wrapper.style.marginBottom = '{{ block.settings.paragraph_spacing }}px';
            table.parentNode.insertBefore(wrapper, table);
            wrapper.appendChild(table);
          }
        });

        const iframes = content.querySelectorAll('iframe');
        iframes.forEach(iframe => {
          if (!iframe.parentElement.classList.contains('iframe-wrapper')) {
            const wrapper = document.createElement('div');
            wrapper.style.position = 'relative';
            wrapper.style.paddingBottom = '56.25%';
            wrapper.style.height = '0';
            wrapper.style.overflow = 'hidden';
            wrapper.style.marginBottom = '{{ block.settings.paragraph_spacing }}px';
            iframe.style.position = 'absolute';
            iframe.style.top = '0';
            iframe.style.left = '0';
            iframe.style.width = '100%';
            iframe.style.height = '100%';
            iframe.parentNode.insertBefore(wrapper, iframe);
            wrapper.appendChild(iframe);
          }
        });
      }
    }

    customElements.define('blog-content-formatter-{{ ai_gen_id }}', BlogContentFormatter{{ ai_gen_id }});
  })();
</script>

{% schema %}
