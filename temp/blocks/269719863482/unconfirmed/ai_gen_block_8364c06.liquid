      "content": "Typography"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow size",
      "default": 14
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 28,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 52
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "Subtitle size",
      "default": 18
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#a46959"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_button_bg",
      "label": "Button background",
      "default": "#a46959"
    },
    {
      "type": "color",
      "id": "cta_button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_button_hover_bg",
      "label": "Button hover background",
      "default": "#835447"
