    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient end",
      "default": "#835447"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
