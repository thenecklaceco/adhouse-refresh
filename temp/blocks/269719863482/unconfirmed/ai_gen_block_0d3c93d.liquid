</contact-social-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactSocial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('contact-social-{{ ai_gen_id }}', ContactSocial{{ ai_gen_id }});
  })();
</script>

