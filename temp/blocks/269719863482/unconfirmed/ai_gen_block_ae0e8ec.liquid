{% doc %}
  @prompt
    Create a warm and elegant Contact Us page for AdHouse.in, an online jewellery brand. The tone should be friendly yet sophisticated, reflecting the beauty and trust associated with jewellery shopping.
    Hero/Welcome Section:
    Add a welcoming headline such as "We'd Love to Hear From You ✨" with a subtext like "Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you."
    Contact Details Section:
    Display the following contact information with icons in a clean card or grid layout:
    
    📞 Phone: +91-XXXXXXXXXX (replace with your number)
    💬 WhatsApp: Chat with us on WhatsApp — "Tap to chat instantly!"
    📧 Email: support@adhouse.in
    🕐 Business Hours: Monday – Saturday, 10:00 AM – 7:00 PM IST
    📍 Address: (Add your city/state or warehouse address if applicable)
    
    Social Media Links Section:
    Add a heading like "Follow Us & Stay Inspired 💎" and include clickable icons for:
    
    Instagram – @adhouse.in
    Facebook – AdHouse Jewellery
    Pinterest – AdHouse.in
    YouTube – AdHouse Official (if applicable)
    
    Contact Form Section:
    Include a simple inquiry form with fields for: Name, Email, Phone Number, Order ID (optional), and Message — with a submit button labeled "Send Message 💌"
    Trust/Reassurance Line at Bottom:
    End with a short note like: "We typically respond within 24 hours. Your trust means everything to us — just like every piece of jewellery we craft."
    Design Notes:
    Use gold, ivory, or rose-gold tones to match a jewellery brand aesthetic. Keep the layout minimal, elegant, and mobile-friendly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-page-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-contact-hero-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-contact-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_subtitle_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
    opacity: 0.9;
  }

  .ai-contact-details-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 24px;
    text-align: center;
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .ai-contact-card-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-contact-card-content-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
    line-height: 1.6;
  }

  .ai-contact-card-link-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    text-decoration: none;
  }

  .ai-contact-card-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-contact-social-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-social-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    font-weight: 600;
  }

  .ai-contact-social-icons-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ai-contact-social-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: {{ block.settings.social_icon_bg }};
    border-radius: 50%;
    color: {{ block.settings.social_icon_color }};
    text-decoration: none;
    font-size: 20px;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-contact-social-link-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    background-color: {{ block.settings.accent_color }};
    color: {{ block.settings.card_background }};
  }

  .ai-contact-form-section-{{ ai_gen_id }} {
    max-width: 700px;
    margin: 0 auto 60px;
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    font-weight: 600;
    text-align: center;
  }

  .ai-contact-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    font-family: inherit;
    background-color: {{ block.settings.card_background }};
    color: {{ block.settings.text_color }};
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
  }

  .ai-contact-trust-{{ ai_gen_id }} {
    text-align: center;
    padding: 24px;
    background-color: {{ block.settings.trust_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-contact-trust-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    opacity: 0.9;
    margin: 0;
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
    text-align: center;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: 16px;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-hero-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.hero_title_size }}px * 0.8);
    }

    .ai-contact-hero-subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.hero_subtitle_size }}px * 0.9);
    }

    .ai-contact-details-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<contact-page-{{ ai_gen_id }} class="ai-contact-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-hero-{{ ai_gen_id }}">
    {% if block.settings.hero_title != blank %}
      <h1 class="ai-contact-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
    {% endif %}
    {% if block.settings.hero_subtitle != blank %}
      <div class="ai-contact-hero-subtitle-{{ ai_gen_id }}">{{ block.settings.hero_subtitle }}</div>
    {% endif %}
  </div>

  <div class="ai-contact-details-{{ ai_gen_id }}">
    {% if block.settings.show_phone %}
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card-icon-{{ ai_gen_id }}">📞</div>
        <h3 class="ai-contact-card-title-{{ ai_gen_id }}">Phone</h3>
        <div class="ai-contact-card-content-{{ ai_gen_id }}">
          {% if block.settings.phone_number != blank %}
            <a href="tel:{{ block.settings.phone_number }}" class="ai-contact-card-link-{{ ai_gen_id }}">
              {{ block.settings.phone_number }}
            </a>
          {% else %}
            +91-XXXXXXXXXX
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_whatsapp %}
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card-icon-{{ ai_gen_id }}">💬</div>
        <h3 class="ai-contact-card-title-{{ ai_gen_id }}">WhatsApp</h3>
        <div class="ai-contact-card-content-{{ ai_gen_id }}">
          {% if block.settings.whatsapp_number != blank %}
            <a href="https://wa.me/{{ block.settings.whatsapp_number | replace: '+', '' | replace: '-', '' | replace: ' ', '' }}" target="_blank" class="ai-contact-card-link-{{ ai_gen_id }}">
              Tap to chat instantly!
            </a>
          {% else %}
            Tap to chat instantly!
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_email %}
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card-icon-{{ ai_gen_id }}">📧</div>
        <h3 class="ai-contact-card-title-{{ ai_gen_id }}">Email</h3>
        <div class="ai-contact-card-content-{{ ai_gen_id }}">
          {% if block.settings.email != blank %}
            <a href="mailto:{{ block.settings.email }}" class="ai-contact-card-link-{{ ai_gen_id }}">
              {{ block.settings.email }}
            </a>
          {% else %}
            support@adhouse.in
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card-icon-{{ ai_gen_id }}">🕐</div>
        <h3 class="ai-contact-card-title-{{ ai_gen_id }}">Business Hours</h3>
        <div class="ai-contact-card-content-{{ ai_gen_id }}">
          {{ block.settings.business_hours }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_address %}
      <div class="ai-contact-card-{{ ai_gen_id }}">
        <div class="ai-contact-card-icon-{{ ai_gen_id }}">📍</div>
        <h3 class="ai-contact-card-title-{{ ai_gen_id }}">Address</h3>
        <div class="ai-contact-card-content-{{ ai_gen_id }}">
          {{ block.settings.address }}
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_social %}
    <div class="ai-contact-social-{{ ai_gen_id }}">
      <h2 class="ai-contact-social-title-{{ ai_gen_id }}">{{ block.settings.social_title }}</h2>
      <div class="ai-contact-social-icons-{{ ai_gen_id }}">
        {% if block.settings.instagram_url != blank %}
          <a href="{{ block.settings.instagram_url }}" target="_blank" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.facebook_url != blank %}
          <a href="{{ block.settings.facebook_url }}" target="_blank" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.pinterest_url != blank %}
          <a href="{{ block.settings.pinterest_url }}" target="_blank" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Pinterest">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M8.5 14.5c.5 2 2 3.5 4.5 3.5 3.5 0 5.5-2.5 5.5-6 0-3-2-5.5-5-5.5-3.5 0-6 2.5-6 6 0 1.5.5 2.5 1.5 3"></path>
            </svg>
          </a>
        {% endif %}

        {% if block.settings.youtube_url != blank %}
          <a href="{{ block.settings.youtube_url }}" target="_blank" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="YouTube">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
              <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_form %}
    <div class="ai-contact-form-section-{{ ai_gen_id }}">
      <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
      
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="ai-contact-form-success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="ai-contact-form-error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="ai-contact-form-{{ ai_gen_id }}">
          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Name *</label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              {% if form.errors %}
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-form-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Email *</label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              autocomplete="email"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Phone Number</label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-order-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Order ID (Optional)</label>
            <input
              type="text"
              id="contact-order-{{ ai_gen_id }}"
              name="contact[order-id]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Message *</label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-form-textarea-{{ ai_gen_id }}"
              required
            ></textarea>
          </div>

          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </button>
        </div>
      {% endform %}
    </div>
  {% endif %}

  {% if block.settings.show_trust_message %}
    <div class="ai-contact-trust-{{ ai_gen_id }}">
      <p class="ai-contact-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_message }}</p>
    </div>
  {% endif %}
</contact-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && form.classList.contains('contact-form')) {
          const successMessage = this.querySelector('.ai-contact-form-success-{{ ai_gen_id }}');
          if (successMessage) {
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      }
    }

    customElements.define('contact-page-{{ ai_gen_id }}', ContactPage{{ ai_gen_id }});
  })();
</script>

