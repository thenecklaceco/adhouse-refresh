{% doc %}
  @prompt
    Create a warm and elegant Contact Us page for AdHouse.in, an online jewellery brand. The tone should be friendly yet sophisticated, reflecting the beauty and trust associated with jewellery shopping.
    Hero/Welcome Section:
    Add a welcoming headline such as "We'd Love to Hear From You ✨" with a subtext like "Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you."
    Contact Details Section:
    Display the following contact information with icons in a clean card or grid layout:
    
    📞 Phone: +91-XXXXXXXXXX (replace with your number)
    💬 WhatsApp: Chat with us on WhatsApp — "Tap to chat instantly!"
    📧 Email: support@adhouse.in
    🕐 Business Hours: Monday – Saturday, 10:00 AM – 7:00 PM IST
    📍 Address: (Add your city/state or warehouse address if applicable)
    
    Social Media Links Section:
    Add a heading like "Follow Us & Stay Inspired 💎" and include clickable icons for:
    
    Instagram – @adhouse.in
    Facebook – AdHouse Jewellery
    Pinterest – AdHouse.in
    YouTube – AdHouse Official (if applicable)
    
    Contact Form Section:
    Include a simple inquiry form with fields for: Name, Email, Phone Number, Order ID (optional), and Message — with a submit button labeled "Send Message 💌"
    Trust/Reassurance Line at Bottom:
    End with a short note like: "We typically respond within 24 hours. Your trust means everything to us — just like every piece of jewellery we craft."
    Design Notes:
    Use gold, ivory, or rose-gold tones to match a jewellery brand aesthetic. Keep the layout minimal, elegant, and mobile-friendly.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.background_color }} 0%, {{ block.settings.background_gradient_color }} 100%);
    padding: 60px 20px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-contact-hero-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_title_size }}px;
    color: {{ block.settings.hero_title_color }};
    margin: 0 0 16px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-contact-hero-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.hero_subtitle_size }}px;
    color: {{ block.settings.hero_subtitle_color }};
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ai-contact-details-section-{{ ai_gen_id }} {
    margin-bottom: 60px;
  }

  .ai-contact-details-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
  }

  .ai-contact-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 32px 24px;
    text-align: center;
    box-shadow: 0 4px 12px rgba(131, 84, 71, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-contact-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(131, 84, 71, 0.12);
  }

  .ai-contact-card-icon-{{ ai_gen_id }} {
    font-size: 32px;
    margin-bottom: 16px;
    display: block;
  }

  .ai-contact-card-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
  }

  .ai-contact-card-content-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.card_text_color }};
    line-height: 1.6;
  }

  .ai-contact-card-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-contact-card-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-contact-social-section-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-contact-social-title-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: {{ block.settings.social_title_color }};
    margin: 0 0 24px;
  }

  .ai-contact-social-links-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-contact-social-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: {{ block.settings.social_icon_background }};
    color: {{ block.settings.social_icon_color }};
    text-decoration: none;
    font-size: 24px;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  .ai-contact-social-link-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    background: {{ block.settings.social_icon_hover_background }};
  }

  .ai-contact-form-section-{{ ai_gen_id }} {
    max-width: 700px;
    margin: 0 auto 60px;
    background: {{ block.settings.form_background }};
    border-radius: {{ block.settings.form_border_radius }}px;
    padding: 40px;
    box-shadow: 0 4px 16px rgba(131, 84, 71, 0.1);
  }

  .ai-contact-form-title-{{ ai_gen_id }} {
    font-size: 28px;
    font-weight: 600;
    color: {{ block.settings.form_title_color }};
    margin: 0 0 24px;
    text-align: center;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: {{ block.settings.form_label_color }};
    margin-bottom: 8px;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.form_input_border }};
    border-radius: 8px;
    font-size: 15px;
    color: {{ block.settings.form_input_text }};
    background: {{ block.settings.form_input_background }};
    transition: border-color 0.3s ease;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.form_input_focus_border }};
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background: {{ block.settings.form_button_background }};
    color: {{ block.settings.form_button_text_color }};
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.form_button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    background: #d4edda;
    color: #155724;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
    text-align: center;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    background: #f8d7da;
    color: #721c24;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .ai-contact-trust-line-{{ ai_gen_id }} {
    text-align: center;
    font-size: 15px;
    color: {{ block.settings.trust_text_color }};
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-contact-page-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-contact-hero-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-contact-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_title_size | times: 0.7 }}px;
    }

    .ai-contact-hero-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.hero_subtitle_size | times: 0.9 }}px;
    }

    .ai-contact-details-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-contact-form-section-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-contact-social-title-{{ ai_gen_id }} {
      font-size: 24px;
    }
  }
{% endstyle %}

<contact-page-{{ ai_gen_id }} class="ai-contact-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-hero-{{ ai_gen_id }}">
      {% if block.settings.hero_title != blank %}
        <h1 class="ai-contact-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
      {% endif %}
      {% if block.settings.hero_subtitle != blank %}
        <div class="ai-contact-hero-subtitle-{{ ai_gen_id }}">{{ block.settings.hero_subtitle }}</div>
      {% endif %}
    </div>

    <div class="ai-contact-details-section-{{ ai_gen_id }}">
      <div class="ai-contact-details-grid-{{ ai_gen_id }}">
        {% if block.settings.show_phone %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <span class="ai-contact-card-icon-{{ ai_gen_id }}">📞</span>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.phone_title }}</h3>
            <div class="ai-contact-card-content-{{ ai_gen_id }}">
              <a href="tel:{{ block.settings.phone_number }}" class="ai-contact-card-link-{{ ai_gen_id }}">
                {{ block.settings.phone_number }}
              </a>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_whatsapp %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <span class="ai-contact-card-icon-{{ ai_gen_id }}">💬</span>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.whatsapp_title }}</h3>
            <div class="ai-contact-card-content-{{ ai_gen_id }}">
              <a href="{{ block.settings.whatsapp_link }}" target="_blank" rel="noopener" class="ai-contact-card-link-{{ ai_gen_id }}">
                {{ block.settings.whatsapp_text }}
              </a>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_email %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <span class="ai-contact-card-icon-{{ ai_gen_id }}">📧</span>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.email_title }}</h3>
            <div class="ai-contact-card-content-{{ ai_gen_id }}">
              <a href="mailto:{{ block.settings.email_address }}" class="ai-contact-card-link-{{ ai_gen_id }}">
                {{ block.settings.email_address }}
              </a>
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_hours %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <span class="ai-contact-card-icon-{{ ai_gen_id }}">🕐</span>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.hours_title }}</h3>
            <div class="ai-contact-card-content-{{ ai_gen_id }}">
              {{ block.settings.business_hours }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.show_address %}
          <div class="ai-contact-card-{{ ai_gen_id }}">
            <span class="ai-contact-card-icon-{{ ai_gen_id }}">📍</span>
            <h3 class="ai-contact-card-title-{{ ai_gen_id }}">{{ block.settings.address_title }}</h3>
            <div class="ai-contact-card-content-{{ ai_gen_id }}">
              {{ block.settings.address }}
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_social %}
      <div class="ai-contact-social-section-{{ ai_gen_id }}">
        <h2 class="ai-contact-social-title-{{ ai_gen_id }}">{{ block.settings.social_title }}</h2>
        <div class="ai-contact-social-links-{{ ai_gen_id }}">
          {% if block.settings.instagram_url != blank %}
            <a href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.facebook_url != blank %}
            <a href="{{ block.settings.facebook_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.pinterest_url != blank %}
            <a href="{{ block.settings.pinterest_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="Pinterest">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.youtube_url != blank %}
            <a href="{{ block.settings.youtube_url }}" target="_blank" rel="noopener" class="ai-contact-social-link-{{ ai_gen_id }}" aria-label="YouTube">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_form %}
      <div class="ai-contact-form-section-{{ ai_gen_id }}">
        <h2 class="ai-contact-form-title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
        
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <div class="ai-contact-form-success-{{ ai_gen_id }}" id="ai-contact-form-success-{{ ai_gen_id }}">
              {{ block.settings.form_success_message }}
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="ai-contact-form-error-{{ ai_gen_id }}" id="ai-contact-form-error-{{ ai_gen_id }}">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-name-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Name *</label>
            <input
              type="text"
              id="contact-name-{{ ai_gen_id }}"
              name="contact[name]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              aria-required="true"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-contact-form-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-contact-form-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-email-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Email *</label>
            <input
              type="email"
              id="contact-email-{{ ai_gen_id }}"
              name="contact[email]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              required
              aria-required="true"
              autocomplete="email"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-phone-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Phone Number</label>
            <input
              type="tel"
              id="contact-phone-{{ ai_gen_id }}"
              name="contact[phone]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
              autocomplete="tel"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-order-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Order ID (Optional)</label>
            <input
              type="text"
              id="contact-order-{{ ai_gen_id }}"
              name="contact[order_id]"
              class="ai-contact-form-input-{{ ai_gen_id }}"
            >
          </div>

          <div class="ai-contact-form-field-{{ ai_gen_id }}">
            <label for="contact-message-{{ ai_gen_id }}" class="ai-contact-form-label-{{ ai_gen_id }}">Message *</label>
            <textarea
              id="contact-message-{{ ai_gen_id }}"
              name="contact[body]"
              class="ai-contact-form-textarea-{{ ai_gen_id }}"
              required
              aria-required="true"
            ></textarea>
          </div>

          <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
            {{ block.settings.form_button_label }}
          </button>
        {%- endform -%}
      </div>
    {% endif %}

    {% if block.settings.trust_line != blank %}
      <div class="ai-contact-trust-line-{{ ai_gen_id }}">
        {{ block.settings.trust_line }}
      </div>
    {% endif %}
  </div>
</contact-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ContactPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && form.classList.contains('contact-form')) {
          const successMessage = this.querySelector('.ai-contact-form-success-{{ ai_gen_id }}');
          if (successMessage) {
            successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      }
    }

    customElements.define('contact-page-{{ ai_gen_id }}', ContactPage{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Contact us page",
  "settings": [
    {
      "type": "header",
      "content": "Hero section"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title",
      "label": "Title",
      "default": "We'd Love to Hear From You ✨"
    },
    {
      "type": "inline_richtext",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "Whether you have a question about our jewellery, need help with your order, or just want to say hello — we're always here for you."
    },
    {
      "type": "range",
      "id": "hero_title_size",
      "label": "Title size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "hero_subtitle_size",
      "label": "Subtitle size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "hero_title_color",
      "label": "Title color",
      "default": "#422a24"
    },
    {
      "type": "color",
      "id": "hero_subtitle_color",
      "label": "Subtitle color",
      "default": "#835447"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_title",
      "label": "Title",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "+91-XXXXXXXXXX"
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp",
      "label": "Show WhatsApp",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_title",
      "label": "Title",
      "default": "WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_text",
      "label": "Link text",
      "default": "Tap to chat instantly!"
    },
    {
      "type": "url",
      "id": "whatsapp_link",
      "label": "WhatsApp link"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show email",
      "default": true
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Title",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_address",
