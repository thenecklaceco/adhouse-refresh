{% doc %}
  @prompt
    Create a responsive “Trust / Features Bar” section for a Shopify theme.
    
    Design Requirements:
    - A horizontal bar with 4 columns (desktop) displaying:
      1. Icon
      2. Title (bold, uppercase)
      3. Subtitle (smaller text below)
    - Example items:
      - WELL TRUSTED — Over 100k customers
      - SUPER FAST — With Express delivery
      - EXPERT HELP — Seven days a week
      - BEST PRICES — Unbeatable value
    
    Layout:
    - Desktop: 4 items in a single row (equal width, centered content)
    - Tablet: 2 items per row
    - Mobile: 1 item per row OR horizontal scroll (toggle option)
    - Proper spacing between items with divider option (optional vertical lines)
    
    Customization (VERY IMPORTANT):
    - Allow adding/removing/reordering items (blocks)
    - Each item should support:
      - Icon (SVG upload or icon picker)
      - Title text
      - Subtitle text
    - Global section settings:
      - Background color / gradient
      - Text color (title + subtitle separately)
      - Icon color
      - Font size (desktop + mobile separately)
      - Font weight
      - Spacing (padding top/bottom, gap between items)
      - Alignment (left / center / right)
    
    Advanced Controls:
    - Separate settings for Desktop and Mobile:
      - Font sizes
      - Spacing
      - Layout (stack vs scroll)
    - Toggle:
      - Show/hide dividers between items
      - Enable hover effect (slight scale or color change)
    - Option to switch between:
      - Center aligned layout
      - Left aligned layout
    
    Performance:
    - Lightweight, no unnecessary JS
    - Use CSS flex/grid
    - Icons should be optimized SVG
    
    Accessibility:
    - Proper semantic structure
    - Alt text support for icons
    
    Output:
    - Clean, modular Shopify section (Liquid + schema)
    - Blocks for each feature item
    - Fully customizable via theme editor
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ block.settings.background_color }};
    {% if block.settings.background_gradient != blank %}
      background: {{ block.settings.background_gradient }};
    {% endif %}
    padding: {{ block.settings.padding_top_desktop }}px 0 {{ block.settings.padding_bottom_desktop }}px;
  }

  .ai-trust-bar-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-trust-bar-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
    align-items: center;
  }

  {% if block.settings.mobile_layout == 'scroll' %}
    @media screen and (max-width: 749px) {
      .ai-trust-bar-grid-{{ ai_gen_id }} {
        display: flex;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        gap: {{ block.settings.gap_mobile }}px;
        padding-bottom: 10px;
      }

      .ai-trust-bar-grid-{{ ai_gen_id }}::-webkit-scrollbar {
        height: 4px;
      }

      .ai-trust-bar-grid-{{ ai_gen_id }}::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 2px;
      }

      .ai-trust-bar-grid-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
        background: {{ block.settings.text_color_title }};
        border-radius: 2px;
        opacity: 0.5;
      }

      .ai-trust-bar-item-{{ ai_gen_id }} {
        flex: 0 0 280px;
        scroll-snap-align: start;
      }
    }
  {% else %}
    @media screen and (max-width: 749px) {
      .ai-trust-bar-grid-{{ ai_gen_id }} {
        grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
        gap: {{ block.settings.gap_mobile }}px;
      }
    }
  {% endif %}

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-trust-bar-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  .ai-trust-bar-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.item_gap }}px;
    position: relative;
  }

  {% if block.settings.show_dividers %}
    .ai-trust-bar-item-{{ ai_gen_id }}:not(:last-child)::after {
      content: '';
      position: absolute;
      right: calc(-{{ block.settings.gap_desktop }}px / 2);
      top: 50%;
      transform: translateY(-50%);
      width: 1px;
      height: 60%;
      background-color: {{ block.settings.divider_color }};
      opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    }

    @media screen and (max-width: 989px) {
      .ai-trust-bar-item-{{ ai_gen_id }}::after {
        display: none;
      }
    }
  {% endif %}

  {% if block.settings.enable_hover %}
    .ai-trust-bar-item-{{ ai_gen_id }} {
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .ai-trust-bar-item-{{ ai_gen_id }}:hover {
      transform: translateY(-4px);
    }

    .ai-trust-bar-item-{{ ai_gen_id }}:hover .ai-trust-bar-icon-{{ ai_gen_id }} {
      color: {{ block.settings.icon_hover_color }};
    }
  {% endif %}

  .ai-trust-bar-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_desktop }}px;
    height: {{ block.settings.icon_size_desktop }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
    transition: color 0.3s ease;
  }

  .ai-trust-bar-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-trust-bar-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-bar-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_desktop }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.text_color_title }};
    margin: 0;
    line-height: 1.2;
    {% if block.settings.title_uppercase %}
      text-transform: uppercase;
      letter-spacing: 0.05em;
    {% endif %}
  }

  .ai-trust-bar-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size_desktop }}px;
    font-weight: {{ block.settings.subtitle_weight }};
    color: {{ block.settings.text_color_subtitle }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-bar-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-trust-bar-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-bar-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-trust-bar-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }
  }
{% endstyle %}

<trust-bar-{{ ai_gen_id }} class="ai-trust-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-bar-container-{{ ai_gen_id }}">
    <div class="ai-trust-bar-grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign icon_key = 'icon_' | append: i
          assign title_key = 'title_' | append: i
          assign subtitle_key = 'subtitle_' | append: i
          assign enabled_key = 'item_' | append: i | append: '_enabled'
          
          assign icon = block.settings[icon_key]
          assign title = block.settings[title_key]
          assign subtitle = block.settings[subtitle_key]
          assign enabled = block.settings[enabled_key]
        %}
        
        {% if enabled %}
          <div class="ai-trust-bar-item-{{ ai_gen_id }}">
            {% if icon != blank %}
              <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
                {{ icon }}
              </div>
            {% endif %}
            
            <div class="ai-trust-bar-content-{{ ai_gen_id }}">
              {% if title != blank %}
                <h3 class="ai-trust-bar-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% endif %}
              
              {% if subtitle != blank %}
                <p class="ai-trust-bar-subtitle-{{ ai_gen_id }}">{{ subtitle }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</trust-bar-{{ ai_gen_id }}>

{% schema %}
